{
  "rewrites": [
    {
      "source": "/api/proxy/:path*",
      "destination": "https://unmixr.com/api/:path*"
    },
    {
      "source": "/api/minimax/:path*",
      "destination": "https://api.minimax.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
