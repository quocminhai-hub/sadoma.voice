{
  "rewrites": [
    {
      "source": "/unmixr-api/:path*",
      "destination": "https://unmixr.com/api/:path*"
    },
    {
      "source": "/minimax-api/:path*",
      "destination": "https://api.minimax.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
